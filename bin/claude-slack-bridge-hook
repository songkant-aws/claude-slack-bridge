#!/usr/bin/env python3
"""Self-contained hook script for Claude Slack Bridge plugin.

Uses only Python stdlib — no venv or pip install needed.
Called by Claude Code hooks with event type as first argument, hook payload on stdin.
"""
import hashlib
import json
import os
import sys
import urllib.request
import urllib.error
from pathlib import Path


def load_port():
    """Read daemon port from config, default 7778."""
    config_file = Path.home() / ".claude" / "slack-bridge" / "config.json"
    if config_file.is_file():
        try:
            with open(config_file) as f:
                return json.load(f).get("daemon_port", 7778)
        except (json.JSONDecodeError, OSError):
            pass
    return 7778


def load_approval_timeout():
    """Read approval timeout from config, default 300."""
    config_file = Path.home() / ".claude" / "slack-bridge" / "config.json"
    if config_file.is_file():
        try:
            with open(config_file) as f:
                return json.load(f).get("approval_timeout_secs", 300)
        except (json.JSONDecodeError, OSError):
            pass
    return 300


def derive_session_key(hook_json):
    """Derive session key from hook stdin JSON."""
    sid = hook_json.get("session_id")
    if sid:
        return str(sid)
    cwd = hook_json.get("cwd", "unknown")
    env_key = os.environ.get("CLAUDE_CODE_SESSION_KEY", "")
    if env_key:
        raw = f"{cwd}:{env_key}"
        return hashlib.sha256(raw.encode()).hexdigest()[:16]
    return cwd


def build_payload(event_type, stdin_json):
    """Build normalized payload from hook stdin JSON."""
    payload = {
        "event": event_type,
        "session_key": derive_session_key(stdin_json),
        "cwd": stdin_json.get("cwd", ""),
    }
    if event_type in ("pre-tool-use", "post-tool-use", "permission-request"):
        payload["tool_name"] = stdin_json.get("tool_name", "")
        payload["tool_input"] = stdin_json.get("tool_input", {})
        payload["tool_use_id"] = stdin_json.get("tool_use_id", "")
    if event_type == "post-tool-use":
        payload["tool_output"] = stdin_json.get("tool_output", "")
        payload["duration_ms"] = stdin_json.get("duration_ms", 0)
    if event_type == "user-prompt":
        payload["prompt"] = stdin_json.get("prompt", "")
    if event_type == "stop":
        payload["response"] = (
            stdin_json.get("last_assistant_message", "")
            or stdin_json.get("response", "")
        )
    if event_type == "notification":
        payload["notification_type"] = stdin_json.get("notification_type", "")
        payload["message"] = stdin_json.get("message", "")
    if event_type == "pre-compact":
        payload["compact_type"] = stdin_json.get("compact_type", "auto")
    return payload


def post_to_daemon(endpoint, payload, port, timeout):
    """POST JSON to daemon. Returns response body or 'error'."""
    url = f"http://127.0.0.1:{port}{endpoint}"
    data = json.dumps(payload).encode()
    req = urllib.request.Request(
        url, data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.read().decode().strip()
    except (urllib.error.URLError, OSError):
        return "error"


# Map CLI-style event names to hook event types
EVENT_MAP = {
    "PreToolUse": "pre-tool-use",
    "PostToolUse": "post-tool-use",
    "PermissionRequest": "permission-request",
    "UserPromptSubmit": "user-prompt",
    "Stop": "stop",
    "SessionStart": "session-start",
    "SessionEnd": "session-end",
    "Notification": "notification",
    "SubagentStop": "subagent-stop",
    "PreCompact": "pre-compact",
    # Also accept already-mapped names
    "pre-tool-use": "pre-tool-use",
    "post-tool-use": "post-tool-use",
    "permission-request": "permission-request",
    "user-prompt": "user-prompt",
    "stop": "stop",
    "session-start": "session-start",
    "session-end": "session-end",
    "notification": "notification",
    "subagent-stop": "subagent-stop",
    "pre-compact": "pre-compact",
}


def main():
    # Skip hooks fired from our own --print subprocess
    if os.environ.get("CLAUDE_SLACK_BRIDGE_PRINT"):
        sys.exit(0)

    if len(sys.argv) < 2:
        sys.exit(0)

    raw_event = sys.argv[1]
    event_type = EVENT_MAP.get(raw_event)
    if not event_type:
        sys.exit(0)

    stdin_data = sys.stdin.read()
    try:
        stdin_json = json.loads(stdin_data) if stdin_data.strip() else {}
    except json.JSONDecodeError:
        sys.exit(0)

    port = load_port()

    # Quick check: if daemon isn't running, exit silently
    import socket
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.settimeout(0.5)
        if s.connect_ex(("127.0.0.1", port)) != 0:
            sys.exit(0)

    payload = build_payload(event_type, stdin_json)
    endpoint = f"/hooks/{event_type}"

    if event_type == "pre-tool-use":
        # Fire-and-forget notification only — no blocking approval.
        # TUI has its own approval UI; blocking here causes double-approval.
        post_to_daemon(endpoint, payload, port, timeout=5)
        sys.exit(0)
    elif event_type == "permission-request":
        # Block and wait for Slack approval, return decision to Claude Code.
        # This replaces TUI's built-in approval prompt.
        timeout = load_approval_timeout() + 10
        result = post_to_daemon(endpoint, payload, port, timeout)
        if result == "rejected":
            output = {
                "hookSpecificOutput": {
                    "hookEventName": "PermissionRequest",
                    "decision": {
                        "behavior": "deny",
                        "message": "Denied via Slack",
                    },
                }
            }
            print(json.dumps(output))
            sys.exit(0)
        elif result == "approved":
            output = {
                "hookSpecificOutput": {
                    "hookEventName": "PermissionRequest",
                    "decision": {"behavior": "allow"},
                }
            }
            print(json.dumps(output))
            sys.exit(0)
        else:
            # Daemon unreachable or timeout — fall through to TUI prompt
            sys.exit(0)
    else:
        post_to_daemon(endpoint, payload, port, timeout=5)
        sys.exit(0)


if __name__ == "__main__":
    main()
